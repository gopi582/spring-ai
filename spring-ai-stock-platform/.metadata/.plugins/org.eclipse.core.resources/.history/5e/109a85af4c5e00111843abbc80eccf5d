package com.spring.ai.config;

import static org.assertj.core.api.Assertions.filter;

import org.springframework.cloud.gateway.route.RouteLocator;
import org.springframework.cloud.gateway.route.builder.RouteLocatorBuilder;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;

import com.spring.ai.filter.JwtFilter;

@Configuration
public class GatewayConfig {

	@Bean
	public RouteLocator routes(RouteLocatorBuilder builder, JwtFilter filter) {

		return builder.routes()

				.route("ai-agent", r -> r.path("/ai/**").filters(f -> f.filter(filter)).uri("http://localhost:8081"))

				.route("auth", r -> r.path("/auth/**").uri("http://localhost:8083"))

				.build();
	}
}
