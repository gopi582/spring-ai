package com.spring.ai.service;

@Component
public class ToolInspector {

    public ToolInspector(ApplicationContext context) {

        context.getBeansWithAnnotation(Component.class)
                .values()
                .forEach(bean -> {

                    System.out.println(
                            "Bean = " + bean.getClass().getName());

                    Arrays.stream(bean.getClass().getMethods())
                            .filter(m -> m.isAnnotationPresent(
                                    org.springframework.ai.tool.annotation.Tool.class))
                            .forEach(m ->
                                    System.out.println(
                                            " TOOL FOUND -> "
                                                    + m.getName()));
                });
    }
}
