package com.spring.ai.controller;

import org.springframework.ai.chat.client.ChatClient;
import org.springframework.ai.chat.client.advisor.MessageChatMemoryAdvisor;
import org.springframework.ai.chat.client.advisor.vectorstore.QuestionAnswerAdvisor;
import org.springframework.ai.chat.memory.ChatMemory;
import org.springframework.ai.vectorstore.VectorStore;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;

@RestController
@RequestMapping("/ai")
public class AgentController {

    private final ChatClient chatClient;
    private final ChatMemory chatMemory;
    private final VectorStore vectorStore;

    public AgentController(
            ChatClient.Builder builder,
            ChatMemory chatMemory,
            VectorStore vectorStore) {

        this.chatClient = builder.build();
        this.chatMemory = chatMemory;
        this.vectorStore = vectorStore;
    }

    @GetMapping("/ask")
    public String ask(
            @RequestParam("q") String q,
            @RequestParam(defaultValue = "1") String sessionId) {

        String lower = q.toLowerCase();

        boolean newsQuery =
                lower.contains("news")
                        || lower.contains("latest");

        boolean priceQuery =
                lower.contains("price")
                        || lower.contains("stock")
                        || lower.contains("share");

        boolean companyQuery =
                lower.contains("company")
                        || lower.contains("profile")
                        || lower.contains("ceo");

        boolean marketQuery =
                lower.contains("gainers")
                        || lower.contains("losers")
                        || lower.contains("market movers");

        /*
         * DYNAMIC SYSTEM PROMPT
         */
        String systemPrompt = """
                You are an enterprise stock AI assistant.
                Always use MCP tools whenever needed.
                Never say context does not contain information
                before checking tools.
                """;

        if (newsQuery) {

            systemPrompt += """
                    Use NEWS tools only.
                    Return latest stock/company news.
                    """;
        }
        else if (priceQuery) {

            systemPrompt += """
                    Use STOCK PRICE tools only.
                    Return live stock prices.
                    """;
        }
        else if (companyQuery) {

            systemPrompt += """
                    Use COMPANY tools only.
                    Return company profile information.
                    """;
        }
        else if (marketQuery) {

            systemPrompt += """
                    Use MARKET MOVERS tools only.
                    Return gainers and losers.
                    """;
        }

        return chatClient.prompt()

                .system(systemPrompt)

                .user(q)

                .advisors(
                        MessageChatMemoryAdvisor.builder(chatMemory)
                                .conversationId(sessionId)
                                .build(),

                        QuestionAnswerAdvisor.builder(vectorStore)
                                .build())

                .call()

                .content();
    }
}