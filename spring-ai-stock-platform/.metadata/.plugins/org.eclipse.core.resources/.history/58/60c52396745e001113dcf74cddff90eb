package com.spring.ai.service;

import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;
import org.springframework.web.reactive.function.client.WebClient;

@Service
public class MarketMoversService {

    private final WebClient webClient;

    @Value("${stock.api.key}")
    private String apiKey;

    public MarketMoversService(WebClient.Builder builder) {

        this.webClient = builder
                .baseUrl("https://api.twelvedata.com")
                .build();
    }

    public String topGainers() {

        return webClient.get()

                .uri(uriBuilder ->
                        uriBuilder.path("/market_movers")
                                .queryParam("direction", "gainers")
                                .queryParam("apikey", apiKey)
                                .build())

                .retrieve()

                .bodyToMono(String.class)

                .block();
    }

    public String topLosers() {

        return webClient.get()

                .uri(uriBuilder ->
                        uriBuilder.path("/market_movers")
                                .queryParam("direction", "losers")
                                .queryParam("apikey", apiKey)
                                .build())

                .retrieve()

                .bodyToMono(String.class)

                .block();
    }
}