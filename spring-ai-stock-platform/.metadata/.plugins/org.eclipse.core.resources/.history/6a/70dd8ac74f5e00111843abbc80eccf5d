package com.spring.ai.service;

import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;
import org.springframework.web.reactive.function.client.WebClient;

@Service
public class StockService {

    private final WebClient webClient;

    @Value("${stock.api.key}")
    private String apiKey;

    public StockService(WebClient.Builder builder) {
        this.webClient = builder.baseUrl("https://api.twelvedata.com")
                .build();
    }

    public String getPrice(String symbol) {

        try {

            StockPriceResponse response = webClient.get()

                    .uri(uriBuilder -> uriBuilder
                            .path("/price")
                            .queryParam("symbol", symbol)
                            .queryParam("apikey", apiKey)
                            .build())

                    .retrieve()

                    .bodyToMono(StockPriceResponse.class)

                    .block();

            if (response == null || response.getPrice() == null) {
                return "Unable to fetch stock price";
            }

            return symbol + " stock price is " +
                    response.getPrice() + " USD";

        } catch (Exception e) {

            return "Error fetching stock price: " + e.getMessage();
        }
    }
}
